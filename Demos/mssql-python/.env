# SQL Server Connection Configuration
# Copy this file to .env and update with your actual database credentials

# ODBC Driver (common options: 'ODBC Driver 17 for SQL Server', 'ODBC Driver 18 for SQL Server')
SQL_DRIVER=ODBC Driver 17 for SQL Server

# SQL Server address (e.g., localhost, servername.database.windows.net)
SQL_SERVER=localhost

# Database name
SQL_DATABASE=master

# SQL Server username
SQL_USERNAME=sa

# SQL Server password
SQL_PASSWORD=your_password_here

# Trust server certificate (set to 'true' for development/self-signed certificates)
SQL_TRUST_CERT=false
